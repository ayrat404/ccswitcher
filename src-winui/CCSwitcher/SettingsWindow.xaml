<Window
    x:Class="CCSwitcher.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tkit="using:CommunityToolkit.WinUI.Controls"
    Title="CCSwitcher — Settings">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom, draggable title bar (content is extended into it via
             ExtendsContentIntoTitleBar in code-behind). -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="48"
              Padding="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="ms-appx:///Assets/appicon.ico"
                   Width="18" Height="18"
                   VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="CCSwitcher"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </Grid>

        <!-- Scrollable settings content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="36,0,36,28">
            <StackPanel Spacing="2" MaxWidth="1000">

                <TextBlock Text="Settings"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,8,0,0"/>

                <InfoBar x:Name="StatusBar"
                         IsOpen="False"
                         IsClosable="True"
                         Margin="0,12,0,0"/>

                <!-- ============================ Accounts ====================== -->
                <Grid Margin="0,28,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Accounts"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center"/>

                    <Button x:Name="ImportBtn"
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            Click="ImportBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B5;" FontSize="14"/>
                            <TextBlock Text="Import Current Login"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="AddTokenBtn"
                            Grid.Column="2"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="AddTokenBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="Add Account"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Account rows are built in code-behind as SettingsCards. -->
                <StackPanel x:Name="AccountsPanel" Spacing="4"/>

                <tkit:SettingsCard x:Name="NoAccountsCard"
                                   Header="No accounts"
                                   Description="Add a token account or import your current Claude Code login."
                                   Visibility="Collapsed">
                    <tkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE77B;"/>
                    </tkit:SettingsCard.HeaderIcon>
                </tkit:SettingsCard>

                <!-- ============================ Proxy ========================= -->
                <TextBlock Text="Proxy"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,28,0,8"/>

                <tkit:SettingsExpander x:Name="ProxyExpander"
                                       Header="Proxy server"
                                       Description="Route Claude Code requests through an HTTP proxy.">
                    <tkit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE968;"/>
                    </tkit:SettingsExpander.HeaderIcon>

                    <ToggleSwitch x:Name="ProxyEnabledToggle"
                                  Toggled="ProxyEnabledToggle_Toggled"/>

                    <tkit:SettingsExpander.Items>
                        <tkit:SettingsCard Header="Proxy URL"
                                           HorizontalContentAlignment="Left"
                                           ContentAlignment="Vertical">
                            <TextBox x:Name="ProxyUrlBox"
                                     MinWidth="320"
                                     HorizontalAlignment="Stretch"
                                     PlaceholderText="http://127.0.0.1:8080"/>
                        </tkit:SettingsCard>

                        <tkit:SettingsCard Header="No-Proxy"
                                           Description="Comma-separated list of hosts"
                                           HorizontalContentAlignment="Left"
                                           ContentAlignment="Vertical">
                            <TextBox x:Name="NoProxyBox"
                                     MinWidth="320"
                                     HorizontalAlignment="Stretch"
                                     PlaceholderText="localhost,127.0.0.1"/>
                        </tkit:SettingsCard>

                        <tkit:SettingsCard>
                            <Button Content="Save Proxy Settings"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="SaveProxyBtn_Click"/>
                        </tkit:SettingsCard>
                    </tkit:SettingsExpander.Items>
                </tkit:SettingsExpander>

                <!-- ============================ Startup ======================= -->
                <TextBlock Text="Startup"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,28,0,8"/>

                <tkit:SettingsCard Header="Launch at Windows startup"
                                   Description="Automatically start CCSwitcher in the system tray when Windows starts.">
                    <tkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7E8;"/>
                    </tkit:SettingsCard.HeaderIcon>
                    <ToggleSwitch x:Name="StartupToggle"
                                  Toggled="StartupToggle_Toggled"/>
                </tkit:SettingsCard>

                <!-- ====================== On switch ========================== -->
                <TextBlock Text="On switch"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,28,0,8"/>

                <tkit:SettingsCard Header="Remember selected model per account"
                                   Description="When switching accounts, save the current model and restore each account's own model.">
                    <tkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8B7;"/>
                    </tkit:SettingsCard.HeaderIcon>
                    <ToggleSwitch x:Name="ModelTrackingToggle"
                                  Toggled="ModelTrackingToggle_Toggled"/>
                </tkit:SettingsCard>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
