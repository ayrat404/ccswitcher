<Window
    x:Class="CCSwitcher.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CCSwitcher — Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Spacing="16">

            <TextBlock Text="CCSwitcher Settings"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,4,0,4"/>

            <InfoBar x:Name="StatusBar"
                     IsOpen="False"
                     IsClosable="True"/>

            <!-- Accounts section -->
            <StackPanel Spacing="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Accounts"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               VerticalAlignment="Center"/>

                    <Button x:Name="ImportBtn"
                            Grid.Column="1"
                            Content="Import Current Login"
                            Margin="0,0,8,0"
                            Click="ImportBtn_Click"/>

                    <Button x:Name="AddTokenBtn"
                            Grid.Column="2"
                            Content="Add Token Account"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="AddTokenBtn_Click"/>
                </Grid>

                <StackPanel x:Name="AccountsPanel" Spacing="2"/>

                <TextBlock x:Name="NoAccountsText"
                           Text="No accounts configured. Add a token account or import your current Claude Code login."
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Proxy section -->
            <StackPanel Spacing="10">
                <TextBlock Text="Proxy Settings"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>

                <ToggleSwitch x:Name="ProxyEnabledToggle"
                              Header="Enable proxy"
                              Toggled="ProxyEnabledToggle_Toggled"/>

                <TextBlock Text="Proxy URL"/>
                <TextBox x:Name="ProxyUrlBox"
                         PlaceholderText="http://127.0.0.1:8080"/>

                <TextBlock Text="No-Proxy (comma-separated)"/>
                <TextBox x:Name="NoProxyBox"
                         PlaceholderText="localhost,127.0.0.1"/>

                <Button Content="Save Proxy Settings"
                        Click="SaveProxyBtn_Click"/>
            </StackPanel>

            <!-- Startup section -->
            <StackPanel Spacing="10">
                <TextBlock Text="Startup"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>

                <ToggleSwitch x:Name="StartupToggle"
                              Header="Launch at Windows startup"
                              Toggled="StartupToggle_Toggled"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
