{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccswitcher",
  "version": "0.1.0",
  "identifier": "com.ayrat404.ccswitcher",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "ccswitcher — Settings",
        "width": 720,
        "height": 560,
        "resizable": true,
        "visible": false,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
